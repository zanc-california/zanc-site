{
  "name": "zac-backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "dotenv -e .env -- ts-node-dev --respawn server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
  "postinstall": "node ./node_modules/prisma/build/index.js generate --schema=./prisma/schema.prisma",
    "create-admin": "dotenv -e .env -- ts-node scripts/createAdmin.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "@supabase/supabase-js": "^2.0.0",
    "@types/nodemailer": "^6.4.17",
    "@types/pdfkit": "^0.17.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.0.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "nodemailer": "^7.0.5",
    "pdfkit": "^0.17.1",
    "prisma": "^6.11.1",
    "stripe": "^12.0.0",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.14",
    "@types/morgan": "^1.9.10",
    "@types/node": "^18.11.18",
    "dotenv-cli": "^8.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": "20.x"
  }
}
