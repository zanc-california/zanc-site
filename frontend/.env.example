# Copy to .env.local and fill in. Vite loads .env.local. Never commit .env.local.
# These same variables are configured in Vercel for production.

# Supabase (auth + database + storage)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Membership — Monthly and Yearly Payment Links
VITE_STRIPE_MEMBERSHIP_MONTHLY=
VITE_STRIPE_MEMBERSHIP_YEARLY=
# Membership — Out-of-State Yearly Payment Link
VITE_STRIPE_MEMBERSHIP_OUTSTATE_YEARLY=

# Insurance — In-State (adult only / adult with dependents)
VITE_STRIPE_INSURANCE_ADULT_INSTATE=
VITE_STRIPE_INSURANCE_ADULT_DEP_INSTATE=

# Insurance — Out-of-State (adult only / adult with dependents)
VITE_STRIPE_INSURANCE_ADULT_OUTSTATE=
VITE_STRIPE_INSURANCE_ADULT_DEP_OUTSTATE=

# Insurance — Seniors (65–70 / 70+)
VITE_STRIPE_INSURANCE_65_70=
VITE_STRIPE_INSURANCE_70_PLUS=

# Optional: next premium due date shown on Insurance page (e.g. January 25, 2027)
# VITE_INSURANCE_NEXT_DUE=

# Optional: display prices on Insurance page (e.g. 50, 120). One per tier:
# VITE_INSURANCE_PRICE_ADULT_INSTATE=, VITE_INSURANCE_PRICE_ADULT_DEP_INSTATE=,
# VITE_INSURANCE_PRICE_ADULT_OUTSTATE=, VITE_INSURANCE_PRICE_ADULT_DEP_OUTSTATE=,
# VITE_INSURANCE_PRICE_65_70=, VITE_INSURANCE_PRICE_70_PLUS=
