# --- Public (Vite) — already used by the app ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Email subscription API (/api/subscribe) ---
# Local: copy to .env.local (Vite loads these for the dev middleware too)
# NEVER use VITE_RESEND_API_KEY — Vite exposes VITE_* to the browser.
RESEND_API_KEY=

# Server-side Supabase (never expose in client). Same project URL as VITE_SUPABASE_URL.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend verified sender (must match your verified domain)
RESEND_FROM=ZANC <hello@updates.zancsac.com>

# Admin notification for new subscribers
ZANC_SUBSCRIBE_ADMIN_EMAIL=zancsac@gmail.com

# Optional: override subscribe endpoint (e.g. separate backend URL)
# VITE_SUBSCRIBE_API_URL=https://your-site.vercel.app/api/subscribe
